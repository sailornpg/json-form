{
  "name": "json-form-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @sailornpg/demo",
    "build": "npm run build --workspace @sailornpg/engine-adapter && npm run build --workspace @sailornpg/form-protocol && npm run build --workspace @sailornpg/renderer-antdv && npm run build --workspace @sailornpg/form-kit && npm run build --workspace @sailornpg/demo",
    "preview": "npm run preview --workspace @sailornpg/demo",
    "publish:preflight": "node ./scripts/publish-preflight.mjs",
    "publish:preflight:low-level": "node ./scripts/publish-preflight.mjs --profile low-level",
    "publish:preflight:business-path": "node ./scripts/publish-preflight.mjs --profile business-path"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vue-tsc": "^3.2.7"
  }
}
